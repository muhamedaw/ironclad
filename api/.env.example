NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database — leave DB_PASSWORD empty to use SQLite (no MySQL needed for local dev)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ironclad_db
DB_USER=root
DB_PASSWORD=
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT
JWT_SECRET=ironclad_dev_secret_key_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=ironclad_dev_refresh_key_also_64_chars_xxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_EXPIRES_IN=30d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug
