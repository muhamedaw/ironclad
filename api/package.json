{
  "name": "ironclad-api",
  "version": "1.0.0",
  "description": "Scalable Node.js/Express backend for Ironclad Car Parts Marketplace",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seeder.js",
    "migrate": "node src/utils/migrate.js",
    "test": "jest --config jest.config.json --runInBand --detectOpenHandles",
    "test:coverage": "jest --config jest.config.json --runInBand --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:seed": "docker compose exec api node src/utils/seeder.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.0",
    "sequelize": "^6.37.3",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sqlite3": "^6.0.1",
    "supertest": "^7.0.0"
  }
}
