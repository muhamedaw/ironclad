# ═══════════════════════════════════════════════════════════════════════════
# IRONCLAD — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════════════
#
# DO NOT commit actual values to git.
# Copy this file to .env and fill in real values.
#
# cp .env.example .env
#
# Files:
#   .env                    → docker-compose (local / VPS)
#   frontend/.env.local     → Vite dev server
#   frontend/.env.production→ Vercel build (set in Vercel dashboard)
#   api/.env                → API service
#   checkout-service/.env   → Checkout service
# ═══════════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────────
# SECTION 1: DATABASE (MySQL)
# ──────────────────────────────────────────────────────────────────────────

# Used by docker-compose to initialise the MySQL container
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password_here
MYSQL_DATABASE=ironclad_db
MYSQL_USER=ironclad
MYSQL_PASSWORD=CHANGE_ME_strong_db_password_here

# Full connection URL (used by Node services directly)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://ironclad:CHANGE_ME_strong_db_password_here@localhost:3306/ironclad_db

# PlanetScale / Railway / Aiven format (if using managed DB)
# DATABASE_URL=mysql://USER:PASSWORD@HOST/DATABASE?ssl={"rejectUnauthorized":true}

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Expose MySQL port locally (set to empty string to not expose in production)
MYSQL_EXPOSED_PORT=3306


# ──────────────────────────────────────────────────────────────────────────
# SECTION 2: REDIS
# ──────────────────────────────────────────────────────────────────────────

REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379
REDIS_EXPOSED_PORT=6379


# ──────────────────────────────────────────────────────────────────────────
# SECTION 3: JWT / AUTH
# ──────────────────────────────────────────────────────────────────────────

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_64_byte_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_different_64_byte_hex_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d


# ──────────────────────────────────────────────────────────────────────────
# SECTION 4: STRIPE (Payment)
# ──────────────────────────────────────────────────────────────────────────

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...           # sk_test_... for sandbox
STRIPE_PUBLISHABLE_KEY=pk_live_...      # pk_test_... for sandbox

# Get from https://dashboard.stripe.com/webhooks after creating a webhook
# Events to listen: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...


# ──────────────────────────────────────────────────────────────────────────
# SECTION 5: PAYPAL
# ──────────────────────────────────────────────────────────────────────────

# Get from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=AYour-PayPal-Client-ID-Here
PAYPAL_CLIENT_SECRET=EYour-PayPal-Client-Secret-Here
PAYPAL_ENV=sandbox                      # Change to "production" for live


# ──────────────────────────────────────────────────────────────────────────
# SECTION 6: URLS / CORS
# ──────────────────────────────────────────────────────────────────────────

# Public URL of your deployed frontend (no trailing slash)
FRONTEND_URL=https://ironclad.vercel.app

# Public URLs of your APIs (used in frontend .env)
VITE_API_URL=https://api.ironclad-parts.com
VITE_CHECKOUT_URL=https://checkout.ironclad-parts.com

# Exposed API ports (for local dev / VPS direct access)
API_EXPOSED_PORT=4000
CHECKOUT_EXPOSED_PORT=4002


# ──────────────────────────────────────────────────────────────────────────
# SECTION 7: YOUTUBE API (Smart Video System)
# ──────────────────────────────────────────────────────────────────────────

# Get from https://console.cloud.google.com → YouTube Data API v3
VITE_YOUTUBE_API_KEY=AIzaSy...


# ──────────────────────────────────────────────────────────────────────────
# SECTION 8: EMAIL (Transactional — Order Confirmations)
# ──────────────────────────────────────────────────────────────────────────

# Recommended: Resend (resend.com) or Postmark
EMAIL_PROVIDER=resend              # resend | postmark | smtp
RESEND_API_KEY=re_...
EMAIL_FROM=orders@ironclad-parts.com
EMAIL_FROM_NAME=Ironclad Auto Parts

# Or SMTP (fallback)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app_specific_password


# ──────────────────────────────────────────────────────────────────────────
# SECTION 9: LOGGING
# ──────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info                     # debug | info | warn | error
NODE_ENV=production


# ──────────────────────────────────────────────────────────────────────────
# SECTION 10: MONITORING (Optional)
# ──────────────────────────────────────────────────────────────────────────

# Sentry (https://sentry.io)
# SENTRY_DSN=https://...@o...ingest.sentry.io/...
# VITE_SENTRY_DSN=https://...@o...ingest.sentry.io/...

# Datadog / New Relic
# DD_API_KEY=...
