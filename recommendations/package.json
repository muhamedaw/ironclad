{
  "name": "ironclad-recommendations",
  "version": "1.0.0",
  "description": "AI-powered recommendation engine for Ironclad Car Parts Marketplace",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/server.js",
    "dev":   "nodemon src/server.js",
    "test":  "jest --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.19.2",
    "express-validator": "^7.2.0"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "nodemon":   "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "verbose": true
  }
}
